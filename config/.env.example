# Hermes 模型配置
# 至少填写一个可用模型供应商的 API Key。
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# DingTalk Stream Mode 必填
# 钉钉应用后台里的 Client ID / AppKey。
DINGTALK_CLIENT_ID=

# 钉钉应用后台里的 Client Secret / AppSecret。
DINGTALK_CLIENT_SECRET=

# 允许调用 Hermes 的钉钉用户。
# 迁移测试可临时填 *，长期运行建议改成指定用户 ID 或日志里的 sender_id。
# 多个值用英文逗号分隔，例如：user_a,user_b
DINGTALK_ALLOWED_USERS=*

# 可选：需要主动发送钉钉消息时再配置。
DINGTALK_WEBHOOK_URL=
DINGTALK_HOME_CHANNEL=
